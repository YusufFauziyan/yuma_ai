{
  "name": "yuma-ai-backend",
  "version": "1.0.0",
  "description": "Yuma AI Backend - Express + Gemini API + MySQL (Prisma)",
  "main": "src/index.js",
  "scripts": {
    "start": "npx prisma generate && npx prisma migrate deploy && node src/index.js",
    "dev": "nodemon src/index.js",
